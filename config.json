{
  "name": "wechat-md-publisher",
  "version": "0.8.31",
  "requiredEnvVars": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
  "skill": {
    "name": "wechat-md-publisher",
    "version": "0.8.31",
    "enabled": true,
    "autoInvoke": false
  },
  "commands": {
    "publish": {
      "script": "./scripts/publish.sh",
      "args": ["publish"],
      "description": "发布文章到微信公众号"
    },
    "draft": {
      "script": "./scripts/publish.sh",
      "args": ["draft"],
      "description": "创建微信公众号草稿"
    },
    "wrapper": {
      "script": "./scripts/publish.sh",
      "args": ["wrapper"],
      "description": "Wrapper 功能管理（文章开头/结尾固定图文）"
    },
    "list-drafts": {
      "script": "./scripts/publish.sh",
      "args": ["list-drafts"],
      "description": "列出所有草稿"
    },
    "list-published": {
      "script": "./scripts/publish.sh",
      "args": ["list-published"],
      "description": "列出已发布文章"
    },
    "themes": {
      "script": "./scripts/publish.sh",
      "args": ["themes"],
      "description": "列出可用主题"
    }
  },
  "environment": {
    "required": [
      "NODE_VERSION>=18.0.0",
      "WECHAT_APP_ID",
      "WECHAT_APP_SECRET"
    ],
    "optional": []
  },
  "install": {
    "type": "npm",
    "command": "npm install -g wechat-md-publisher",
    "package": "wechat-md-publisher",
    "global": true,
    "autoInstall": false,
    "autoUpdate": false,
    "riskLevel": "moderate",
    "riskReason": "全局安装第三方 npm 包，会在主机上执行未经审计的代码。安装前请审计源码。",
    "requiresApproval": true,
    "source": {
      "type": "npm",
      "registry": "https://registry.npmjs.org",
      "package": "wechat-md-publisher",
      "repository": "https://github.com/sipingme/wechat-md-publisher",
      "license": "Apache-2.0"
    },
    "verification": {
      "command": "wechat-pub --version",
      "expectedBinary": "wechat-pub"
    }
  },
  "dependencies": {
    "npm": [
      "wechat-md-publisher@latest",
      "jsdom@^27.4.0",
      "form-data-encoder@^4.1.0",
      "formdata-node@^6.0.3"
    ]
  },
  "credentials": {
    "required": ["WECHAT_APP_ID", "WECHAT_APP_SECRET"],
    "storage": {
      "location": "~/.config/wechat-md-publisher-nodejs/",
      "encryption": "AES-256",
      "handler": "wechat-md-publisher npm 包",
      "handlerRepo": "https://github.com/sipingme/wechat-md-publisher",
      "auditFile": "src/services/account.ts"
    },
    "securityNote": "凭证加密由上游 npm 包处理。使用前请审计 https://github.com/sipingme/wechat-md-publisher/blob/main/src/services/account.ts"
  },
  "permissions": {
    "filesystem": {
      "read": ["*.md", "*.jpg", "*.png", "*.gif"],
      "write": ["~/.config/wechat-md-publisher-nodejs/"]
    },
    "network": {
      "domains": ["api.weixin.qq.com", "mp.weixin.qq.com"]
    }
  }
}
